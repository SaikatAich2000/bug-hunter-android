         assignments / @mentions, default for activity. -->
    <string name="fcm_channel_mentions_name">Mentions</string>
    <string name="fcm_channel_mentions_desc">When someone @mentions you in a comment.</string>
    <string name="fcm_channel_assignments_name">Assignments</string>
    <string name="fcm_channel_assignments_desc">When a bug, task, or requirement is assigned to you.</string>
    <string name="fcm_channel_activity_name">Activity</string>
    <string name="fcm_channel_activity_desc">Status changes, new comments, and other updates on items you follow.</string>
    <string name="fcm_default_channel_id" translatable="false">bh_activity</string>


