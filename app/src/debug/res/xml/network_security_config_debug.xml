<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security policy.

  Production release builds use the system default, which forbids
  cleartext HTTP. This debug-only override permits cleartext, but ONLY
  to the explicit local dev hosts listed below — never globally. Scoping
  to <domain-config> (instead of a blanket <base-config>) keeps the
  attack surface tiny: every other destination is still HTTPS-only even
  in debug.

  Hosts that work out of the box:
    - http://10.0.2.2:8000   (Android emulator → host loopback)
    - http://10.0.3.2:8000   (Genymotion emulator → host loopback)
    - http://localhost:8000  (via `adb reverse tcp:8000 tcp:8000`)
    - http://127.0.0.1:8000  (same, explicit loopback)

  Testing on a REAL device over your LAN? Add your laptop's IP as one
  more <domain> entry below, e.g.:
    <domain includeSubdomains="true">192.168.1.42</domain>

  The release manifest does NOT reference this file, so the production
  APK is unaffected.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
